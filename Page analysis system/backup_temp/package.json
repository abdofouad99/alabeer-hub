{
  "name": "alabeer-page-analysis",
  "version": "1.0.0",
  "description": "نظام تحليل صفحات الويب الشامل مع الذكاء الاصطناعي",
  "main": "index.html",
  "scripts": {
    "start": "http-server . -p 3000",
    "build": "echo 'No build step required'",
    "test": "echo 'Run API tests manually'",
    "lint": "eslint js/*.js",
    "lint:fix": "eslint js/*.js --fix",
    "format": "prettier --write js/*.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "migrate": "cd api && php migrate.php",
    "test:cache": "curl http://localhost/api/test-cache.php",
    "test:log": "curl http://localhost/api/test-log.php",
    "test:rate-limit": "curl http://localhost/api/test-rate-limit.php"
  },
  "keywords": [
    "page-analysis",
    "seo",
    "ai",
    "web-scraping",
    "performance"
  ],
  "author": "Alabeer Hub",
  "license": "Proprietary",
  "devDependencies": {
    "http-server": "^14.1.1",
    "eslint": "^8.32.0",
    "prettier": "^2.8.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alabeer/alabeer-page-analysis.git"
  },
  "bugs": {
    "url": "https://github.com/alabeer/alabeer-page-analysis/issues"
  },
  "homepage": "https://alabeer.com"
}