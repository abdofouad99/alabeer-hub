{
    "name": "alabeer/page-analysis-system",
    "description": "نظام تحليل صفحات الويب الشامل مع الذكاء الاصطناعي",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Alabeer Hub",
            "email": "support@alabeer.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "google/cloud-bigquery": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "Alabeer\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php api/migrate.php",
        "setup": "php api/migrate.php",
        "cache-clear": "rm -rf cache/*",
        "logs-clear": "rm -f logs/*.log",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
