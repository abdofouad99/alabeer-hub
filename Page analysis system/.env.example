# ============================================================
# .env.example — Page Analysis System / Growth Lab
# انسخ إلى .env وعبّئ القيم الحقيقية. .env مُستثنى من Git.
# ============================================================

# ── قاعدة البيانات (MariaDB / MySQL) ─────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
# Local by Flywheel غالباً على بورت غير قياسي (مثلاً 10242)
DB_NAME=growth_lab
DB_USER=growth
DB_PASS=growthpass
DB_CHARSET=utf8mb4

# ── أولوية مزودي الذكاء الاصطناعي ────────────────────────────
# قائمة CSV. يجرّب الكود كل مزود بالترتيب حتى ينجح أحدهم.
# الخيارات: gemini, groq, pekpik, deepseek, openai, nvidia
AI_PRIORITY=gemini,groq,pekpik

# ── Gemini (Google) — الأساسي ────────────────────────────────
# يدعم مفتاحاً واحداً أو عدة مفاتيح للـ rotation (افصلها بفواصل).
GEMINI_KEYS=
GEMINI_MODEL=gemini-1.5-flash

# ── Groq (Fallback أول) ──────────────────────────────────────
GROQ_KEY=

# ── Pekpik (Fallback ثاني — مزود مقدّم) ──────────────────────
PEKPIK_BASE_URL=https://aiapiv2.pekpik.com/v1
PEKPIK_FLAGSHIP_KEYS=
PEKPIK_PRO_KEYS=
PEKPIK_GEMINI_KEYS=
PEKPIK_KEYS=

# ── Fallbacks إضافية (اختيارية) ──────────────────────────────
DEEPSEEK_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120
OPENAI_CONNECT_TIMEOUT=15
OPENAI_PROMPT_MAX_CHARS=12000
OPENAI_MAX_TOKENS=3500
NVIDIA_KEYS=

# ── Apify (سحب البيانات الحقيقية) ────────────────────────────
# تفعيل/تعطيل scrapers عبر Apify (Facebook, Instagram, TikTok, Twitter, Ads).
# ضع هذه على false لإيقاف كل استدعاءات Apify (تقليل التكلفة/الحصة).
ENABLE_APIFY=true
ENABLE_ADS_LIBRARY=true
# تشغيل Google PageSpeed Insights (اختياري — يحتاج GOOGLE_PAGESPEED_KEY)
ENABLE_PAGESPEED=false
# تشغيل enrich متعمّق للمنافسين — يضاعف استهلاك Apify ×6 لكل منافس.
# عطّله افتراضياً، فعّله فقط على حسابات Apify المدفوعة.
ENABLE_COMPETITOR_ENRICH=false

# قائمة tokens مفصولة بفواصل (rotation + load balancing).
# مثال: APIFY_TOKENS=apify_api_aaaa,apify_api_bbbb
APIFY_TOKENS=
# (اختياري) دعم backward-compat للأسماء المفردة. لو ضبطتها هنا تُدمج
# تلقائياً مع APIFY_TOKENS أعلاه. مفيد للترقية من إعدادات قديمة.
APIFY_TOKEN=
APIFY_TOKEN_1=
APIFY_TOKEN_2=

# Apify Actor IDs — بصيغة "username/actor-name" أو UUID
APIFY_ACTOR_IG=apify/instagram-scraper
APIFY_ACTOR_FB=apify/facebook-pages-scraper
APIFY_ACTOR_TIKTOK=clockworks/free-tiktok-scraper
APIFY_ACTOR_TWITTER=u6ppkMWAx2E2MpEuF
APIFY_ACTOR_WEBSITE=apify/website-content-crawler
APIFY_ACTOR_ADS_FB=whoareyouanas/meta-ad-scraper
ADS_DEFAULT_COUNTRY=SA

# ── Meta / Facebook (إعلانات + Ads Library) ──────────────────
FACEBOOK_ACCESS_TOKEN=
META_ADS_TOKEN=

# ── إعدادات التطبيق ──────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ── البريد (اختياري) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=


# ── Google PageSpeed Insights (يفعّل عند ENABLE_PAGESPEED=true) ─
GOOGLE_PAGESPEED_KEY=

# ── Cache ────────────────────────────────────────────────────
# driver: file | apcu | redis (file هو الأكثر توافقاً وأمانًا افتراضياً)
CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_TTL=3600
CACHE_PATH=./cache
# REDIS_URL و REDIS_TOKEN يستخدمان فقط لو CACHE_DRIVER=redis
REDIS_URL=
REDIS_TOKEN=

# ── Logging ──────────────────────────────────────────────────
# المستوى: DEBUG | INFO | WARNING | ERROR
LOG_ENABLED=true
LOG_LEVEL=INFO
LOG_PATH=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# ── Rate limiting (لكل IP) ───────────────────────────────────
# الكود في api/rate_limit.php يستخدم هذه القيم الثلاث صراحةً.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=300
RATE_LIMIT_PER_DAY=2000
