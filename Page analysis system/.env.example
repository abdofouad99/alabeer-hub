# ============================================================
# .env.example — Page Analysis System / Growth Lab
# انسخ إلى .env وعبّئ القيم الحقيقية. .env مُستثنى من Git.
# ============================================================

# ── قاعدة البيانات (MariaDB / MySQL) ─────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
# Local by Flywheel غالباً على بورت غير قياسي (مثلاً 10242)
DB_NAME=growth_lab
DB_USER=growth
DB_PASS=growthpass
DB_CHARSET=utf8mb4

# ── أولوية مزودي الذكاء الاصطناعي ────────────────────────────
# قائمة CSV. يجرّب الكود كل مزود بالترتيب حتى ينجح أحدهم.
# الخيارات: gemini, groq, pekpik, deepseek, openai, nvidia
AI_PRIORITY=gemini,groq,pekpik

# ── Gemini (Google) — الأساسي ────────────────────────────────
# يدعم مفتاحاً واحداً أو عدة مفاتيح للـ rotation (افصلها بفواصل).
GEMINI_KEYS=
GEMINI_MODEL=gemini-1.5-flash

# ── Groq (Fallback أول) ──────────────────────────────────────
GROQ_KEY=

# ── Pekpik (Fallback ثاني — مزود مقدّم) ──────────────────────
PEKPIK_BASE_URL=https://aiapiv2.pekpik.com/v1
PEKPIK_FLAGSHIP_KEYS=
PEKPIK_PRO_KEYS=
PEKPIK_GEMINI_KEYS=
PEKPIK_KEYS=

# ── Fallbacks إضافية (اختيارية) ──────────────────────────────
DEEPSEEK_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120
OPENAI_CONNECT_TIMEOUT=15
OPENAI_PROMPT_MAX_CHARS=30000
OPENAI_MAX_TOKENS=3500
NVIDIA_KEYS=

# ── Apify (سحب البيانات الحقيقية) ────────────────────────────
# تفعيل/تعطيل scrapers عبر Apify (Facebook, Instagram, TikTok, Twitter, Ads).
# ضع هذه على false لإيقاف كل استدعاءات Apify (تقليل التكلفة/الحصة).
ENABLE_APIFY=true
ENABLE_ADS_LIBRARY=true
# تشغيل Google PageSpeed Insights (اختياري — يحتاج GOOGLE_PAGESPEED_KEY)
ENABLE_PAGESPEED=false
# تشغيل enrich متعمّق للمنافسين — يضاعف استهلاك Apify ×6 لكل منافس.
# عطّله افتراضياً، فعّله فقط على حسابات Apify المدفوعة.
ENABLE_COMPETITOR_ENRICH=false
ENABLE_TT_COMMENTS=true

# ── Instagram Deep Scan ──────────────────────────────────────
# enable_ig_comments: استدعاء Comments Actor لأفضل 5 منشورات → Sentiment + Objections
# enable_ig_vision:   تحليل صور Instagram عبر OpenAI Vision (gpt-4o-mini)
# enable_ig_stories:  محاولة سحب Stories + Highlights
# enable_ig_sentiment_ai: استخدام OpenAI لتحليل المشاعر (دقة أعلى من heuristic)
ENABLE_IG_COMMENTS=true
ENABLE_IG_VISION=false
ENABLE_IG_STORIES=false
ENABLE_IG_SENTIMENT_AI=true
IG_COMMENTS_TOP_POSTS=5
IG_VISION_TOP_IMAGES=5

# ── Facebook Deep Scan (V3) ──────────────────────────────────
# enable_fb_comments:     سحب تعليقات أفضل 5 منشورات → تحليل مشاعر
# enable_fb_vision:       تحليل صور Facebook عبر OpenAI Vision (مكلف)
# enable_fb_sentiment_ai: استخدام OpenAI لتلخيص المشاعر
# fb_max_posts:           عدد منشورات Facebook المسحوبة (افتراضي 50)
ENABLE_FB_COMMENTS=true
ENABLE_FB_VISION=false
ENABLE_FB_SENTIMENT_AI=true
FB_COMMENTS_TOP_POSTS=5
FB_VISION_TOP_IMAGES=5
FB_MAX_POSTS=50

# قائمة tokens مفصولة بفواصل (rotation + load balancing).
# مثال: APIFY_TOKENS=apify_api_aaaa,apify_api_bbbb
APIFY_TOKENS=
# (اختياري) دعم backward-compat للأسماء المفردة. لو ضبطتها هنا تُدمج
# تلقائياً مع APIFY_TOKENS أعلاه. مفيد للترقية من إعدادات قديمة.
APIFY_TOKEN=
APIFY_TOKEN_1=
APIFY_TOKEN_2=

# Apify Actor IDs — بصيغة "username/actor-name" أو UUID
APIFY_ACTOR_IG=apify/instagram-scraper
APIFY_ACTOR_IG_COMMENTS=SbK00X0JYCPblD2wp
APIFY_ACTOR_IG_STORIES=apify/instagram-stories-scraper
APIFY_ACTOR_FB=apify/facebook-pages-scraper
APIFY_ACTOR_FB_COMMENTS=us5srxAYnsrkgUv2v
APIFY_ACTOR_TIKTOK=clockworks/free-tiktok-scraper
APIFY_ACTOR_TWITTER=u6ppkMWAx2E2MpEuF
APIFY_ACTOR_WEBSITE=apify/website-content-crawler
APIFY_ACTOR_ADS_FB=JJghSZmShuco4j9gJ
ADS_DEFAULT_COUNTRY=SA

# عدد المنشورات المراد سحبها لكل منصة (اختياري — للتحكم في تكلفة Apify)
TIKTOK_VIDEOS_LIMIT=200
TWITTER_TWEETS_LIMIT=100

# ── Meta / Facebook (إعلانات + Ads Library) ──────────────────
FACEBOOK_ACCESS_TOKEN=
META_ADS_TOKEN=

# ── إعدادات التطبيق ──────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ── Google PageSpeed Insights ─────────────────────────────────
# مفتاح API لـ Google PageSpeed (اختياري — بدونه يعمل بحد 25 طلب/يوم)
GOOGLE_PAGESPEED_KEY=

# ── الكاش (Cache) ────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_TTL=3600

# ── التسجيل (Logging) ────────────────────────────────────────
LOG_LEVEL=INFO

# ── البريد (اختياري) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ═══════════════════════════════════════════════════════
# Competitor Analysis System v2 — Sprint 2 (Discovery)
# ═══════════════════════════════════════════════════════

# --- Discovery ---
COMPETITOR_DISCOVERY_MODE=auto              # auto | local | digital | hybrid
COMPETITOR_MAX_CANDIDATES=30                # عدد المرشحين قبل الفلترة
COMPETITOR_TOP_N=5                          # عدد المنافسين النهائي
APIFY_ACTOR_GOOGLE_PLACES=LmLOOMYKuCUrYsda2
APIFY_ACTOR_GOOGLE_SEARCH=YNcgn7yiLc72ayYeB
APIFY_ACTOR_GOOGLE_SEARCH_FALLBACK=V8SFJw3gKgULelpok
APIFY_ACTOR_FB_PAGES_SEARCH=YAg3YuPbbASz7JzWG
APIFY_ACTOR_FB_PAGES_SEARCH_FALLBACK=HBdQuY0Qwd2bDGM4a
APIFY_ACTOR_GOOGLE_MAPS_REVIEWS=Xb8osYTtOjlsgI6k9

# --- Quality Gates ---
COMPETITOR_MIN_VALIDATION_SCORE=40
COMPETITOR_REQUIRE_CATEGORY_MATCH=false     # متساهل لتغطية أكثر
COMPETITOR_RETRY_IF_LESS_THAN=3             # أعد المحاولة لو نتج < 3
