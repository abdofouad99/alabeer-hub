# ملفات السجلات
logs/
*.log

# cache files
cache/
*.cache

# ملفات التكوين الحساسة
config.local.php
.env
*.env
config/*.php
api/config.local.php
api/secrets.php

# ملفات أُنشئت في وقت التشغيل وقد تحوي توكينات حساسة
cache/setup_token.txt
cache/*.lock

# ملفات قاعدة البيانات
*.sql
!schema_mysql.sql

# مجلدات Node.js
node_modules/
npm-debug.log*

# مجلدات Python
__pycache__/
*.pyc
*.pyo

# ملفات الاختبارات
tests/results/
phpunit.xml

# ملفات النسخ الاحتياطي
*.backup
*.bak
*~

# ملفات النظام
.DS_Store
Thumbs.db

# ملفات المحرر
.vscode/
.idea/
*.swp
*.swo

# ملفات الاختبار المؤقتة
test-*.php
debug-*.php

# ============================================================
# سكريبتات الإصلاح/الحقن المؤقتة — ممنوع رفعها
# ============================================================
# هذه الأنماط تمنع رفع سكريبتات تعدّل ملفات الإنتاج أثناء التشغيل
# (مثل سكريبت يقرأ report.html ثم يحقن فيه <script> tag).
# هذه السكريبتات هشة بطبيعتها (أخطاء coercion في PHP، duplicate insert،
# تخريب encoding) وقد تسبّب فساد ملفات لا يمكن إصلاحه.
# الإصلاحات الحقيقية تتم بتعديل الملف المصدر ورفعه عبر PR.
fix-*.php
fix_*.php
api/fix.php
api/fix-*.php
api/fix_*.php
inject-*.php
inject_*.php
api/inject*.php
patch-*.php
patch_*.php
repair-*.php
repair_*.php
hotfix-*.php
hotfix_*.php
api/check_braces.php
api/check-*.php

# ============================================================
# نسخ احتياطية للـ PHP لا يجب أن تُرفع للـ Git
# ============================================================
api/*_backup.php
api/*.backup-*.php

# ============================================================
# Backup directories and archives — never commit binary backups
# ============================================================
backup_temp/
_backups/
backup_*.zip
*_Backup_*.zip
System_Backup_*.zip
