# ============================================================
# .htaccess - Page Analysis System (Root)
# يعزل النظام عن WordPress تماماً + يُعطّل الـ rewrite الموروث.
# ============================================================

# ── 1) عزل WordPress: تعطيل أي rewrite موروث من WP root ─────
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# ── 2) منع listing للمجلدات + UTF-8 ─────────────────────────
Options -Indexes
AddDefaultCharset UTF-8

# ── 3) منع تنفيذ ملفات حساسة لو وُجدت في الجذر بالخطأ ───────
<FilesMatch "^(config\.php|db\.php|\.env(\..*)?|composer\.(json|lock))$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── 4) رؤوس الأمان ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── 5) Cache للأصول الثابتة ─────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 month"
</IfModule>

# ── 6) ضغط GZIP ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── 7) منع executors خطرة في حال أُهمل أي ملف صدفة ──────────
<FilesMatch "\.(env|ini|log|sh|sql|bak|backup|swp|orig)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>
