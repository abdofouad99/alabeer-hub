# ============================================================
# api/.htaccess — حماية شاملة بصياغة Apache 2.2/2.4 معاً
# المنطق: deny-by-default ثم whitelist للـ public endpoints فقط.
# ============================================================

# ── 1) عزل WordPress (لو مرفوع تحت WP) ──────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# ── 2) Default DENY على جميع .php (Apache 2.2 + 2.4) ────────
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── 3) WHITELIST: Public endpoints (يُستدعون من JS) ─────────
<FilesMatch "^(submit|analyze|status|result|page-scan|get-assessment|scan|health|run|ads-fetch|csrf)\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Allow from all
    </IfModule>
</FilesMatch>

# ── 4) DEBUG / ADMIN endpoints: localhost only ──────────────
<FilesMatch "^(clear-cache|debug-data|debug-pipeline|maintenance|rerun-ai|migrate|db-migrate|db-test|init|fix_corrupted|check_braces|admin_dashboard|dump|dump-latest)\.php$">
    <IfModule mod_authz_core.c>
        Require local
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
        Allow from 127.0.0.1
        Allow from ::1
        Allow from localhost
    </IfModule>
</FilesMatch>

# ── 5) منع امتدادات حساسة + النسخ الاحتياطية ────────────────
<FilesMatch "\.(env|ini|log|sh|sql|bak|backup|swp|orig)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── 6) منع ملفات النسخ الاحتياطية وphp _backup ──────────────
<FilesMatch "(_backup|\.backup-[0-9-]+|backup_temp)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── 7) Listing + Server signature off ───────────────────────
Options -Indexes
ServerSignature Off
FileETag None

# ── 8) ضغط GZIP ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/javascript
</IfModule>

# ── 9) Cache للأصول ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>
